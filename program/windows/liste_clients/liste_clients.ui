QFrame#toolbarFrame {
    background-color: #ffffff;
    border-bottom: 1px solid #e2e8f0;
}
QToolButton#tbNew, QToolButton#tbEdit, QToolButton#tbDelete,QToolButton#tbFermer,
QToolButton#tbPrint, QToolButton#tbExportExcel, QToolButton#tbTransform,
QToolButton#tbDuplicate{
    background-color: transparent;
    border: none;
    padding: 4px 12px;
    margin: 0px;
    color: #374151;
    font: 400 10pt &quot;Overpass&quot;;
}
