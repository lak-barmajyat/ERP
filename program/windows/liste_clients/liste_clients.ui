       <property name="styleSheet">
        <string notr="true">
QFrame {
    background-color: #f6f6f8;
    border-bottom: 1px solid #e2e8f0;
}

QLabel, QLabel#labelDocNumber, QLabel#labelPeriod, QLabel#labelStatus, QLabel#labelcodeclient {
    color: #6b7280;
    font: 600 8pt &quot;Overpass&quot;;
    text-transform: uppercase;
}

QLineEdit, QLineEdit#editDocNumber, QLineEdit#editcodeclient {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 6px 10px;
    font: 400 9pt &quot;Overpass&quot;;
    color: #374151;
}
QLineEdit:focus, QLineEdit#editDocNumber:focus, QLineEdit#editcodeclient:focus {
    border-color: #135bec;
}

QDateEdit, QDateEdit#dateTo {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 6px 10px;
    font: 400 9pt &quot;Overpass&quot;;
    color: #374151;
}
QDateEdit:focus, QDateEdit#dateTo:focus {
    border-color: #135bec;
}
QDateEdit::drop-down, QDateEdit#dateTo::drop-down {
    border: none;
    width: 18px;
}
QDateEdit::down-arrow, QDateEdit#dateTo::down-arrow {
    image: url(program/assets/global/down_blue_arrow.svg);
    width: 10px;
    height: 10px;
}

QComboBox {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
    padding: 6px 10px;
    font: 400 9pt &quot;Overpass&quot;;
    color: #374151;
}
QComboBox::drop-down {
    border: none;
    width: 18px;
}
QComboBox::down-arrow {
    image: url(program/assets/global/down_blue_arrow.svg);
    width: 10px;
    height: 10px;
}

QPushButton {
    background-color: #135bec;
    border-radius: 8px;
    border: none;
    padding: 8px 18px;
    color: #ffffff;
    font: 600 9pt &quot;Overpass&quot;;
}
QPushButton:hover {
    background-color: #0f4bc4;
}
