       <property name="styleSheet">
        <string notr="true">
QTableWidget#tableClients {
    background-color: #ffffff;
    border: none;
    gridline-color: #e2e8f0;
    font: 400 9pt &quot;Overpass&quot;;
    color: #374151;
    selection-background-color: rgba(19,91,236,0.08);
    selection-color: #111827;
    outline: 0;
}
QTableWidget#tableClients::item {
    padding: 6px 10px;
    border-bottom: 1px solid #f3f4f6;
}
QTableWidget#tableClients::item:alternate {
    background-color: #f9fafb;
}
QTableWidget#tableClients::item:selected {
    background-color: rgba(19,91,236,0.08);
    color: #111827;
}
QTableWidget#tableClients::item:hover {
    background-color: #f9fafb;
}
QHeaderView::section {
    background-color: #f9fafb;
    color: #374151;
    font: 600 9pt &quot;Overpass&quot;;
    padding: 8px 10px;
    border: none;
    border-right: 1px solid #e2e8f0;
    border-bottom: 2px solid #e2e8f0;
}
QHeaderView::section:last {
    border-right: none;
}
