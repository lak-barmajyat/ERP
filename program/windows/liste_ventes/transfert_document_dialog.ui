              <property name="styleSheet">
               <string notr="true">QLineEdit#CodeEditLine { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 6px 10px; font: 500 10pt &quot;Overpass&quot;; color: #374151; } 

QLineEdit#CodeEditLine:hover { border-color: #d1d5db; }

 QLineEdit#CodeEditLine:focus { border-color: #1d7ae2; }

/* --- Added Read-Only State --- */
QLineEdit#CodeEditLine[readOnly=&quot;true&quot;] {
    background-color: #f9fafb;    /* Light grey &quot;locked&quot; background */
    color: #9ca3af;               /* Lighter grey text */
    border: 1px solid #f3f4f6;    /* Very faint border */
}

/* Prevents the hover/focus colors from appearing when read-only */
QLineEdit#CodeEditLine[readOnly=&quot;true&quot;]:hover,
QLineEdit#CodeEditLine[readOnly=&quot;true&quot;]:focus {
    border-color: #f3f4f6;
}</string>
